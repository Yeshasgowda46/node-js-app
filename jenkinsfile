pipeline {
    agent any

    stages {


        stage('Build Docker Image') {
            steps {
                sh 'docker build -t node-app .'
            }
        }

        stage('Push to DockerHub') {
            steps {
                sh 'docker tag node-app yashasgowdads/node-app'
                sh 'docker push yashasgowdads/node-app'
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                docker stop node-app-container || true
                docker rm node-app-container || true
                docker run -d -p 4000:3000 --name node-app-container yashasgowdads/node-app
                '''
            }
        }
    }
}
